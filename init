# Load functions.
. /functions.sh

echo -e "\e[31m\e[1m>\e[34m\e[1m>\e[31m\e[1m> \e[39m\e[0mLoading fake time..."
date -s "2026-01-01 12:00:00"

run_hooks init

# Prepare dirs
run dodir /dev /newroot /sbin /proc /sys /etc /var/log /var/run /run /run/cryptsetup
for d in /lib /usr/lib; do
   # ! -e && ! -h: also skip broken symlinks
   if [ -d "${d}" ] && [ ! -e "${d}64" ] && [ ! -h "${d}64" ]; then
      run ln -s "${d}" "${d}64"
   fi
done
unset -v d

# Basic /dev content, we need it as fast as possible.
[ ! -e /dev/console ]  && run mknod /dev/console c 5 1
[ ! -e /dev/null ]     && run mknod /dev/null c 1 3
[ ! -e /dev/tty ]      && run mknod /dev/tty c 5 0
[ ! -e /dev/urandom ]  && run mknod /dev/urandom c 1 9
[ ! -e /dev/random ]   && run mknod /dev/random c 1 8
[ ! -e /dev/zero ]     && run mknod /dev/zero c 1 5

# Save IFS so we can easly restore it if we ever change it.
readonly default_ifs="${IFS}"

# Basic
kernelver="$(uname -r)"
ver="$(cat /VERSION)"

sleep 2
# Clear the screen
clear

einfo "better-initramfs ${ver}. Linux kernel ${kernelver}.\n"
echo -e "\nWelcome to better-initramfs ${ver}. Linux kernel ${kernelver}.\n" > /etc/motd

sleep 1

emount /proc /sys > /dev/null

# Disable kernel messages from popping onto the screen
echo 0 > /proc/sys/kernel/printk

process_commandline_options
InitializeBusybox > /dev/null
emount /dev > /dev/null
run_hooks early
loadkeymap

# Let's try to support all possible combinations of storage layers.
use bcache register_bcache_devices
use softraid InitializeSoftwareRaid && use bcache register_bcache_devices
use lvm InitializeLVM && use bcache register_bcache_devices
use luks InitializeLUKS && use lvm InitializeLVM && use bcache register_bcache_devices
use rescueshell rescueshell
use swsusp && SwsuspResume
use tuxonice TuxOnIceResume
run_hooks pre_newroot_mount
use rootdelay rootdelay

  sleep 3

if mount LABEL=BATOCERA /newroot 2>/dev/null; then

echo -e "\e[31m\e[1m>\e[34m\e[1m>\e[31m\e[1m> \e[39m\e[0mBatocera for PS4 seems to be installed! Trying to boot now..."


	 # Mount SHARE temp
    mkdir -p /newroot/userdata
    mount LABEL=SHARE /newroot/userdata 2>/dev/null
	
	UPDATE_FILE="/newroot/userdata/batocera/batocera_update.tar.xz"
    UPDATE_SHA="/newroot/userdata/batocera/batocera_update.tar.xz.sha256"

    if [ -f "$UPDATE_FILE" ]; then

        echo "======================================"
        echo " Batocera UPDATE detected!"
        echo "======================================"
        sleep 2

        if [ ! -f "$UPDATE_SHA" ]; then
            echo "ERROR: Missing SHA256 file!"
            rescueshell
        fi

        cd /newroot/userdata/batocera
        echo "Verifying SHA256 checksum..."

        EXPECTED=$(cat batocera_update.tar.xz.sha256)

        if command -v pv >/dev/null 2>&1; then
            ACTUAL=$(pv "$UPDATE_FILE" | sha256sum | cut -d " " -f1)
        else
            ACTUAL=$(sha256sum "$UPDATE_FILE" | cut -d " " -f1)
        fi

        if [ "$EXPECTED" != "$ACTUAL" ]; then
            echo "ERROR: SHA256 mismatch!"
            rescueshell
        fi

        echo "SHA256 OK."

        echo "Archive validation OK."
		
		echo "Umount partitions..."
        cd /
        sync
        umount /newroot/userdata
        umount /newroot
        sleep 2

        get_part() {
        blkid | grep "LABEL=\"$1\"" | cut -d: -f1
        }

        SHAREDEV=$(get_part SHARE)
        BATODEV=$(get_part BATOCERA)

        if [ -z "$SHAREDEV" ] || [ -z "$BATODEV" ]; then
            echo "FATAL: Required partitions not found!"
            rescueshell
        fi

        if [ "$SHAREDEV" = "$BATODEV" ]; then
            echo "FATAL: SHARE and BATOCERA are the same device!"
            rescueshell
        fi
		
		mkdir -p /mnt/share-temp

        mount "$SHAREDEV" /mnt/share-temp || rescueshell

        UPDATE_FILE="/mnt/share-temp/batocera/batocera_update.tar.xz"

        echo "Formatting BATOCERA..."
        mke2fs -t ext4 -F -L BATOCERA -O ^has_journal "$BATODEV" > /dev/null 2>&1 || {
            echo "FATAL: format failed"
            rescueshell
        }

        sync
        sleep 1
        partprobe

        mkdir -p /mnt/batocera-temp

        mount "$BATODEV" /mnt/batocera-temp || rescueshell

        echo "Extracting update..."
        if command -v pv >/dev/null 2>&1; then
            pv "$UPDATE_FILE" | tar -xpJf - -C /mnt/batocera-temp --numeric-owner --warning=none
        else
            tar -xpJf "$UPDATE_FILE" -C /mnt/batocera-temp --numeric-owner --warning=none
        fi || {
            echo "FATAL: extraction failed"
            rescueshell
        }

		
		echo -e "\nPreparing batocera config files..."

		if [ -n "$SHAREDEV" ]; then
			output=$(blkid "$SHAREDEV" | awk 'BEGIN{FS="[=\"]"} {print $(NF-4)}')

		if [ -n "$output" ]; then
			echo "OK: detected UUID for userdata: $output"

		cat >> /mnt/batocera-temp/boot/batocera-boot.conf <<EOT
sharedevice=DEV $output
splash.screen.enabled=1
system.hostname=BATOCERA
EOT
			echo "OK: batocera-boot.conf updated"
			
		# Ensure /boot/boot directory exists (Batocera expects this)
		if [ ! -d /mnt/batocera-temp/boot/boot ]; then
			mkdir -p /mnt/batocera-temp/boot/boot && echo " Created /boot/boot"
		fi

		# Create batocera.board only once
		BOARD_FILE="/mnt/batocera-temp/boot/boot/batocera.board"

		if [ ! -f "$BOARD_FILE" ]; then
			echo "PS4" > "$BOARD_FILE"
			echo "Created batocera.board"
		else
			echo "batocera.board already exists"
		fi	
			
		else
			echo "ERROR: failed to extract UUID from $SHARE_PART"
			fi
		else
			echo "ERROR: SHARE partition not found"
		fi

        echo -e "\e[31m\e[1m>\e[34m\e[1m>\e[31m\e[1m> \e[39m\e[0mAdding EAP key..."
        cp /key/eap_hdd_key.bin /mnt/batocera-temp/etc/cryptmount > /dev/null
        #cp /lib/firmware/edid/my_edid.bin /newroot/lib/firmware/edid > /dev/null
		
		echo -e "\n\e[31m\e[1m>\e[34m\e[1m>\e[31m\e[1m> \e[39m\e[0mUpdate completed."
		
		echo -e "\n\e[31m\e[1m>\e[34m\e[1m>\e[31m\e[1m> \e[39m\e[0mClean updates files..."
        rm /mnt/share-temp/batocera/batocera_update.tar.xz*
        sync
		
		echo "Umount partitions..."
        sync
        umount /mnt/share-temp
        umount /mnt/batocera-temp
        sleep 2

		if mount LABEL=BATOCERA /newroot 2>/dev/null; then
			echo -e "\e[31m\e[1m>\e[34m\e[1m>\e[31m\e[1m> \e[39m\e[0mBatocera for PS4 seems to be installed! Trying to boot now..."
		else
			echo -e "\e[31m\e[1m>\e[34m\e[1m>\e[31m\e[1m> \e[33m\e[0mNo batocera installation detected, aborting!"
			rescueshell
		fi
    fi

    # --- OverlayFS setup (Batocera compatible) ---
    
    echo ""
    echo "======================================"
    echo " Batocera OverlayFS initialization"
    echo "======================================"

    mkdir -p /overlay

    mount -t tmpfs -o size=256M tmpfs /overlay

    echo "[1/8] Creating overlay directories..."

    mkdir -p /overlay/base || echo "ERROR: cannot create /overlay/base"
    mkdir -p /overlay/overlay || echo "ERROR: cannot create /overlay/overlay"
    mkdir -p /overlay/work || echo "ERROR: cannot create /overlay/work"  
    mkdir -p /overlay/saved || echo "ERROR: cannot create /overlay/saved"

    echo "[2/8] Moving real rootfs to base..."
    if mount --move /newroot /overlay/base; then
        echo "OK: rootfs moved to /overlay/base"
    else
        echo "FATAL: cannot move rootfs to base"
    fi

    echo "[3/8] Creating empty newroot..."
    mkdir -p /newroot || echo "ERROR: cannot create /newroot"

    echo "[4/8] Checking for persistent overlay (BATOCERA)..."

    OVERLAY_FILE="/overlay/base/boot/boot/overlay"
    USE_SAVED_OVERLAY=0

    if [ -f "$OVERLAY_FILE" ]; then
        echo "OK: overlay file found ($OVERLAY_FILE)"
        echo "Mounting persistent overlay file..."

        if mount -t ext4 -o ro,loop "$OVERLAY_FILE" /overlay/saved; then
            echo "OK: overlay file mounted at /overlay/saved"

            echo "Copy saved overlay into RAM overlay..."
            cp -a /overlay/saved/. /overlay/overlay/

            umount /overlay/saved
            USE_SAVED_OVERLAY=1
        else
            echo "ERROR: failed to mount overlay file"
        fi
    else
        echo "INFO: no overlay file found, using RAM overlay only"
    fi


    echo "[5/8] Mounting final overlay filesystem..."
    if [ "$USE_SAVED_OVERLAY" -eq 1 ]; then
        echo "Using: saved overlay + RAM overlay"
    else
        echo "Using: RAM overlay only"
    fi
    mount -t overlay overlay \
            -o rw,lowerdir=/overlay/base,upperdir=/overlay/overlay,workdir=/overlay/work \
            /newroot || echo "FATAL: overlayfs mount failed"
	
	echo "[6/8] Mounting persistent userdata..."
	mkdir -p /newroot/userdata

	if mount LABEL=SHARE /newroot/userdata; then
		echo "OK: /userdata mounted persistently"
	else
		echo "WARN: failed to mount SHARE partition"
	fi

#    echo "[5.5/7] Moving real /boot into new root..."
#    mkdir -p /newroot/boot
#    mount --move /boot /newroot/boot || echo "FATAL: failed to move /boot"

    echo "[7/8] Recreating mountpoints in new root..."
    #mkdir -p /newroot/userdata
    mkdir -p /newroot/proc
    mkdir -p /newroot/sys
    mkdir -p /newroot/dev
    mkdir -p /newroot/run
    mkdir -p /newroot/tmp

    echo "[8/8] OverlayFS setup completed"
    echo "======================================"
    echo ""
  
  sleep 2

    echo "Remounting BATOCERA system partition for disk size reporting..."

    mkdir -p /mnt/batocera-real

    if mount LABEL=BATOCERA /mnt/batocera-real; then
        echo "OK: BATOCERA remounted at /mnt/batocera-real"
    else
        echo "FATAL: cannot remount BATOCERA"
    fi
    
    mkdir -p /newroot/boot
    echo "Bind folder /boot BATOCERA partition on /boot..."
    if mount --bind /mnt/batocera-real/boot /newroot/boot; then
        echo "OK: Bind folder /boot BATOCERA partition on /boot"
    else
        echo "FATAL: cannot Bind folder /boot BATOCERA partition on /boot"
    fi
    
    echo "Umount mnt/batocera-real..."
    if umount /mnt/batocera-real; then
        echo "OK: Umount mnt/batocera-real"
    else
        echo "FATAL: cannot umount mnt/batocera-real"
    fi
    rmdir /mnt/batocera-real

    emount /newroot/usr > /dev/null
	cleanup > /dev/null
	moveDev > /dev/null
	eumount /sys /proc > /dev/null
	run_hooks pre_switch_root > /dev/null

    # Rebind overlay RAM dirs into newroot so userspace can see them
    mkdir -p /newroot/overlay
    mount --move /overlay /newroot/overlay || echo "FATAL: failed to move /overlay"
	boot_newroot > /dev/null
else
  echo -e "\e[31m\e[1m>\e[34m\e[1m>\e[31m\e[1m> \e[33m\e[0mBatocera for PS4 is not installed!"
	echo -e "\e[31m\e[1m>\e[34m\e[1m>\e[31m\e[1m> \e[39m\e[0mSwitching to installation wizard..."
	sleep 2
	exec install.sh
fi

rescueshell
